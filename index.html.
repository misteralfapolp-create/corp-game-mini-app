<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Корпоративные Игры</title>
    <!-- Подключаем библиотеку Supabase (доступ к БД) -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <!-- Подключаем библиотеку VK Bridge (общение с VK) -->
    <script src="vk-bridge.js"></script>
</head>
<body>
    <div id="app">
        <h2>Ваш статус:</h2>
        <!-- Сюда выведем информацию об игроке -->
        <p id="player-info">Загрузка...</p>
        
        <!-- Секция для владельца компании (будет скрыта) -->
        <div id="owner-panel" style="display: none;">
            <h3>Панель компании</h3>
            <!-- Список "безработных" игроков для найма -->
            <ul id="jobless-list"></ul>
        </div>
    </div>

    <script>
        // ================= 1. НАСТРОЙКИ =================
        // ЗАМЕНИТЕ на свои ключи из Supabase (Project Settings -> API)
        const SUPABASE_URL = 'https://ВАШ_ID.supabase.co'; 
        const SUPABASE_ANON_KEY = 'ВАШ_ANON_KEY'; 
        
        // Инициализация клиента Supabase
        const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
        
        // Переменная для хранения ID текущего игрока
        let currentUserVkId = null; 

        // ================= 2. ИНИЦИАЛИЗАЦИЯ ПРИЛОЖЕНИЯ =================
        // Эта функция запускается при открытии приложения
        async function initApp() {
            try {
                // Шаг 1: Получаем данные пользователя из VK
                const user = await vkBridge.send('VKWebAppGetUserInfo');
                currentUserVkId = user.id;
                
                console.log('Пользователь VK:', user); // Для отладки

                // Шаг 2: Проверяем, есть ли игрок в базе данных
                const { data: existingPlayer, error: selectError } = await supabase
                    .from('players')
                    .select('*')
                    .eq('vk_id', currentUserVkId)
                    .single(); // .single() значит, что мы ожидаем только одну запись или null

                // Обработка ошибки запроса (кроме "не найдено")
                if (selectError && selectError.code !== 'PGRST116') {
                    throw selectError;
                }

                // Шаг 3: Если игрока нет в базе, добавляем его
                if (!existingPlayer) {
                    console.log('Новый игрок! Добавляем в базу...');
                    const { error: insertError } = await supabase
                        .from('players')
                        .insert([
                            { 
                                vk_id: currentUserVkId, 
                                first_name: user.first_name, 
                                last_name: user.last_name 
                            }
                        ]);

                    if (insertError) throw insertError;
                    
                    // Обновляем страницу, чтобы отобразить статус нового игрока
                    location.reload();
                    return; // Прерываем выполнение, т.к. страница обновится
                } 
                
                // Шаг 4: Если игрок существует, отображаем его данные
                else {
                    displayPlayerInfo(existingPlayer);
                    // Если игрок — владелец компании, показываем панель управления
                    if (existingPlayer.company === 'Владелец') {
                        showOwnerPanel();
                    }
                }

            } catch (error) {
                // Шаг 5: Обработка ошибок
                console.error('Ошибка при инициализации:', error);
                document.getElementById('player-info').textContent = 'Ошибка загрузки. Попробуйте позже.';
            }
        }

        // ================= 3. ФУНКЦИИ ОТОБРАЖЕНИЯ =================
        
        // Показывает имя, фамилию и текущий статус игрока
        function displayPlayerInfo(player) {
            const infoElement = document.getElementById('player-info');
            if (player.company && player.company !== 'Биржа труда') {
                infoElement.textContent = `${player.first_name} ${player.last_name} — Работает в компании ${player.company}`;
            } else {
                infoElement.textContent = `${player.first_name} ${player.last_name} — Безработный (Биржа труда)`;
            }
        }

        // Загружает и показывает список безработных для найма
        async function showOwnerPanel() {
            document.getElementById('owner-panel').style.display = 'block'; // Делаем панель видимой
            
            // Получаем из БД всех, у кого статус "Биржа труда"
            const { data: joblessPlayers, error } = await supabase
                .from('players')
                .select('*')
                .eq('status', 'Биржа труда');

            if (error) {
                console.error('Ошибка загрузки биржи:', error);
                return;
            }

            const listElement = document.getElementById('jobless-list');
            listElement.innerHTML = ''; // Очищаем список

            // Для каждого безработного создаём строчку с кнопкой
            joblessPlayers.forEach(player => {
                const listItem = document.createElement('li');
                listItem.textContent = `${player.first_name} ${player.last_name} `;
                
                const hireButton = document.createElement('button');
                hireButton.textContent = 'Нанять за 100 монет';
                // По нажатию вызываем функцию найма
                hireButton.onclick = () => hirePlayer(player.vk_id);
                
                listItem.appendChild(hireButton);
                listElement.appendChild(listItem);
            });
        }

        // ================= 4. ЛОГИКА НАЙМА =================
        async function hirePlayer(employeeVkId) {
            // ID компании-нанимателя (в прототипе это просто vk_id владельца)
            const companyName = `Компания_${currentUserVkId}`; 
            
            // Обновляем запись нанятого игрока в БД
            const { error } = await supabase
                .from('players')
                .update({ 
                    company: companyName, 
                    status: 'Работает' 
                })
                .eq('vk_id', employeeVkId); // Где vk_id равен ID нанятого

            if (error) {
                alert('Ошибка найма!');
                console.error(error);
            } else {
                alert('Сотрудник успешно нанят!');
                showOwnerPanel(); // Обновляем список безработных
            }
        }

        // ================= 5. СТАРТ ПРИЛОЖЕНИЯ =================
        // Ждём, пока загрузится весь HTML, и запускаем главную функцию
        document.addEventListener('DOMContentLoaded', initApp);
    </script>
</body>
</html>
